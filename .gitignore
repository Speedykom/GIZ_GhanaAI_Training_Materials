# Source files - don't push
*.qmd
*.md
*.html
*.Rmd
*.rst
*.py

# Generated files except outputs we want
**/*.quarto_ipynb
.quarto/
_files/
_freeze/

# Datasets (too large, download from source)
*.csv
*.xlsx
*.json
*.parquet
*/data/
*/dataset*/
*/GTSRB/
*/cassava_dataset/

# Cache and temporary files
__pycache__/
*.pyc
*.pyo
*.egg-info/
.DS_Store
*.ipynb_checkpoints
.venv/
venv/

# Keep only these formats
!*.ipynb
!*.pdf
!*.pptx

# Generated auxiliary files
*.aux
*.log
*.out
*.tex
