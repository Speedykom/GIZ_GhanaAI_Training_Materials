# Ignore all files by default
*
*/

# But allow directories to be traversed
!*/

# Keep these files
!.gitignore
!README.md

# Track source files (Quarto) and dependencies
!*.qmd
!*.py
!*.ipynb
!*.pptx
!*.pdf
!*.csv

# Don't track generated/backup files
*.html
*.Rmd
*.rst
*.backup
*.bak
**/*.quarto_ipynb
.quarto/
_files/
_freeze/
*/data/
*/dataset*/
*/GTSRB/
*/cassava_dataset/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.DS_Store
*.ipynb_checkpoints
.venv/
venv/
*.aux
*.log
*.out
*.tex

/.quarto/
