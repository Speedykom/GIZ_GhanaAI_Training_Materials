```{python}
#| eval: false

# 1. The Parent Class
class Device:
    def __init__(self, brand, battery_level=100):
        self.brand = ... # Assign the brand parameter
        self.battery_level = ... # Assign the battery_level parameter
        
    def charge(self):
        self.battery_level = 100
        print(f"{self.brand} is fully charged!")

# 2. The Child Class (Inherits from Device)
