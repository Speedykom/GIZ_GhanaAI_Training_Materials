#| code-fold: true
#| code-summary: "Show Solution"

images = [
    
    {"filename": "cassava_01.jpg", "confidence": 0.92, "disease": "mosaic"},
    {"filename": "cassava_02.jpg", "confidence": 0.78, "disease": "healthy"},
    {"filename": "cassava_03.jpg", "confidence": 0.95, "disease": "blight"},
    {"filename": "cassava_04.jpg", "confidence": 0.65, "disease": "healthy"},
    {"filename": "cassava_05.jpg", "confidence": 0.88, "disease": "brown_streak"},
    {"filename": "cassava_06.jpg", "confidence": 0.91, "disease": "mosaic"},
    {"filename": "cassava_07.jpg", "confidence": 0.72, "disease": "green_mite"},
    {"filename": "cassava_08.jpg", "confidence": 0.84, "disease": "blight"},
    {"filename": "cassava_09.jpg", "confidence": 0.97, "disease": "healthy"},
    {"filename": "cassava_10.jpg", "confidence": 0.81, "disease": "brown_streak"}

]

# Filter for confidence >= 0.80
high_confidence = list(filter(lambda img: img["confidence"] >= 0.80, images))

# Sort by confidence (highest first)
high_confidence.sort(key=lambda img: img["confidence"], reverse=True)

print("High-confidence results:")
for img in high_confidence:
    print(f"  {img['filename']}: {img['confidence']} - {img['disease']}")
```
:::

